# PostgreSQL (para Docker Compose)
POSTGRES_USER=maca
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_SEGURO
POSTGRES_DB=maca_informes
DATABASE_URL=postgresql://maca:CAMBIAR_PASSWORD_SEGURO@db:5432/maca_informes

# Seguridad
SECRET_KEY=CAMBIAR_SECRET_KEY_MIN_32_CHARS_RANDOM

# Dominio
BASE_DOMAIN=tudominio.com
APP_URL=https://api.tudominio.com
FRONTEND_URL=https://tudominio.com

# Superadmin
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=CAMBIAR_PASSWORD_SUPERADMIN
SUPERADMIN_EMAIL=tu@email.com

# SMTP Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_cuenta@gmail.com
SMTP_PASSWORD=app_password_de_gmail
SMTP_FROM=tu_cuenta@gmail.com

# Storage — cambiar a "r2" en producción
STORAGE_ROOT=data
STORAGE_BACKEND=local
R2_ACCOUNT_ID=tu_account_id_cloudflare
R2_ACCESS_KEY=tu_r2_access_key
R2_SECRET_KEY=tu_r2_secret_key
R2_BUCKET=nombre_del_bucket
R2_URL_EXPIRY_SECONDS=3600
