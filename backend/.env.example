# PostgreSQL (para Docker Compose)
POSTGRES_USER=novex-freeradio
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_SEGURO
POSTGRES_DB=radiologia_db
DATABASE_URL=postgresql://novex-freeradio:CAMBIAR_PASSWORD_SEGURO@db:5432/radiologia_db

# Seguridad
SECRET_KEY=CAMBIAR_SECRET_KEY_MIN_32_CHARS_RANDOM
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Dominio
BASE_DOMAIN=novex.cloud
APP_URL=https://novex.cloud
FRONTEND_URL=https://novex.cloud

# Superadmin
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=CAMBIAR_PASSWORD_ADMIN
SUPERADMIN_EMAIL=tu@email.com

# SMTP Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_cuenta@gmail.com
SMTP_PASSWORD=app_password_de_gmail
SMTP_FROM=tu_cuenta@gmail.com

# Storage — cambiar a "r2" en producción
STORAGE_ROOT=data
STORAGE_BACKEND=r2
R2_ACCOUNT_ID=tu_account_id_cloudflare
R2_ACCESS_KEY=tu_r2_access_key
R2_SECRET_KEY=tu_r2_secret_key
R2_BUCKET=maca-radiologia
R2_URL_EXPIRY_SECONDS=86400
